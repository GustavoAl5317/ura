# ═══════════════════════════════════════════
# URA AI — configuração
# ═══════════════════════════════════════════

TZ=America/Fortaleza

# ── Portas ──────────────────────────────────
AUDIOSOCKET_PORT=9019   # TCP para o Asterisk AudioSocket
SIDECAR_PORT=9020       # HTTP para registrar caller ID antes da chamada
ADMIN_PORT=9021         # Painel de gestão (UI + API)
ADMIN_ENABLED=1
ADMIN_API_KEY=troque-por-uma-chave-forte
URA_ENABLED=1

# ── Monitor OpenAI (painel) ─────────────────
# org-... em platform.openai.com → Settings → Organization
OPENAI_ORG_ID=org-...
# Chave Admin (read-only) em platform.openai.com → Admin keys — NÃO use a sk- normal
OPENAI_ADMIN_KEY=
# Créditos que você comprou na conta (para estimar saldo: prepaid − gasto)
OPENAI_PREPAID_USD=100
# Limite só para ALERTAS no painel (não é saldo real da OpenAI)
OPENAI_BUDGET_USD=100
OPENAI_ALERT_THRESHOLD_PCT=20
OPENAI_POLL_MS=300000
# Monitora login na platform.openai.com (requer audit logging ativo na org)
OPENAI_AUDIT_MONITOR=1
OPENAI_AUDIT_POLL_MS=300000
# Alertas internos: celular com DDD ou ID de grupo Evolution (@g.us)
ADMIN_ALERT_WHATSAPP=
ADMIN_ALERT_WEBHOOK_URL=

# ── OpenAI Realtime ─────────────────────────
OPENAI_API_KEY=sk-...
REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_SCHEMA=ga
OPENAI_VOICE=shimmer
TEMPERATURE=0.65
MAX_TOKENS=768

# ── TTS ─────────────────────────────────────
# openai = voz nativa do Realtime (menor latência)
# elevenlabs = ElevenLabs (mais natural para telefonia)
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk-...
ELEVENLABS_VOICE_ID=ORgG8rwdAiMYRug8RJwR
# Voz masculina (João) — ID em elevenlabs.io → Voices → copiar Voice ID de voz MASCULINA
# Obrigatório para João soar como homem (diferente de ELEVENLABS_VOICE_ID)
ELEVENLABS_VOICE_ID_MALE=
# 1 = alterna Ana/João a cada nova chamada (requer ELEVENLABS_VOICE_ID_MALE)
VOICE_ALTERNATE=0
# Modelos: eleven_flash_v2_5 (recomendado) | eleven_multilingual_v2 (mais natural) | eleven_turbo_v2_5 (rápido, mais chiado)
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
# pcm_24000 = melhor qualidade antes de converter para 8 kHz do Asterisk
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
# 0.65–0.75 = voz estável; muito alto = robótica; muito baixo = instável
ELEVENLABS_STABILITY=0.68
# 0.60–0.75; muito alto pode chiarr
ELEVENLABS_SIMILARITY=0.68
# 0 = menos chiado em telefonia; 1 = mais volume mas pode distorcer
ELEVENLABS_SPEAKER_BOOST=0

# ── VAD ─────────────────────────────────────
TURN_DETECTION_TYPE=semantic_vad
# low = menos interrupções por ruído; medium = resposta mais rápida
TURN_DETECTION_EAGERNESS=low
TURN_DETECTION_THRESHOLD=0.65
TURN_DETECTION_SILENCE_MS=900
DEFER_ASSISTANT_AUDIO_WHILE_USER_SPEAKS=1
# 1 = OpenAI cancela geração; interrupção do áudio ElevenLabs é local
REALTIME_INTERRUPT_RESPONSE=1
SPEECH_STOP_DELAY_MS=900
SPEECH_STOP_DELAY_COLLECTING_MS=1600
# Ignora ruído curto / eco falso (ms)
MIN_SPEECH_MS=450
INTERRUPT_ARM_MS=400

# ── Buffers de áudio ────────────────────────
# START_BUFFER_MS = pré-buffer antes de tocar (usa o maior entre PRE e START)
# MAX_BUFFER_MS = teto só para áudio nativo OpenAI em streaming; use 0 com ElevenLabs
PRE_BUFFER_MS=60
START_BUFFER_MS=280
MIN_BUFFER_MS=160
MAX_BUFFER_MS=0
END_PAUSE_MS=450
INPUT_MUTE_MS=1500
INPUT_RING_MS=10000

# ── Som de espera (consulta / digitação) ─────
# WAV ou MP3 (MP3 convertido automaticamente via ffmpeg-static).
# Deixe vazio para o teclado sintético embutido.
WAIT_SOUND_PATH=assets/wait-typing.mp3
# Só toca teclado se consulta SGP demorar mais que isso (ms). 0 = sempre toca.
TOOL_TYPING_DELAY_MS=0
TOOL_SLOWDOWN_MS=2500
# WAIT_SOUND_URL=https://exemplo.com/typing.mp3
# ── SGP ─────────────────────────────────────
SGP_BASE_URL=https://sys.aquitelecom.com
SGP_APP=appAquitelecom
SGP_TOKEN=43b8ec19-ac06-4c86-aeb5-e798176acca7
SGP_TIMEOUT_MS=8000
SGP_RETRIES=0
# 0 = consultas mais rápidas (ONU só quando consultar_onu)
SGP_EXIBIR_CONEXAO=0
SGP_SERVICOS_DADOS=0

# ── Zabbix (monitoramento de rede) ───────────
ZABBIX_ENABLED=1
ZABBIX_URL=https://zabbix.aquitelecom.com
ZABBIX_USER=monitorGerador
ZABBIX_PASSWORD="sua_senha_aqui"
ZABBIX_TIMEOUT_MS=12000
# Padrões de busca nos triggers Zabbix (separados por |)
ZABBIX_SEARCH_PATTERNS=ALERTA: cto off|Queda da Interface|POP

# ── GeoSite ─────────────────────────────────
GEOSITE_ENABLED=1
COVERAGE_USE_GEOSITE_ONLY=1
GEOSITE_BASE_URL=https://telecom.digicade.com.br/geosite-telecom-api
GEOSITE_USERNAME=suportAPI
GEOSITE_PASSWORD=senh@7404
GEOSITE_RAIO_METROS=600
GEOSITE_TIMEOUT_MS=12000

# ── WhatsApp (Evolution API) ─────────────────
WHATSAPP_API_URL=http://10.169.0.20:8080
WHATSAPP_INSTANCE=aqutelecom01
WHATSAPP_API_KEY=...
WHATSAPP_SALES_GROUP_ID=120363xxxxxxxxx@g.us  # ID do grupo de vendas (copiar do Evolution)

# ── Asterisk AMI ─────────────────────────────
AST_AMI_HOST=127.0.0.1
AST_AMI_PORT=5038
AST_AMI_USER=ura
AST_AMI_PASS="sua_senha_aqui"
AST_AMI_TRANSFER_EXTEN=8000        # Ramal de fila/atendente
AST_AMI_TRANSFER_CONTEXT=from-internal

# ── Empresa ──────────────────────────────────
COMPANY_NAME=Aquitelecom
AGENT_NAME=Ana
AGENT_NAME_MALE=João

# ── Chamados SGP ────────────────────────────
FEATURE_CHAMADO=1
CHAMADO_OCORRENCIA_TIPO=5
CHAMADO_TIPO_CLASSIFICACOES=5

# ── Debug ───────────────────────────────────
LOG_LEVEL=full
DEBUG_TX=0
DEBUG_ASR=0
